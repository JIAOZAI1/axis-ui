{
  "name": "@jiaozai1/axis-ui",
  "version": "0.4.4",
  "description": "企业级 Vue 3 组件库,基于设计 Token 体系构建,支持暗色模式与主题定制",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jiaozai1/axis-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/axis-ui.umd.cjs",
  "module": "./dist/axis-ui.js",
  "exports": {
    ".": {
      "import": "./dist/axis-ui.js",
      "require": "./dist/axis-ui.umd.cjs"
    },
    "./dist/axis-ui.css": "./dist/axis-ui.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "keywords": [
    "vue3",
    "component-library",
    "design-tokens",
    "ui"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0"
  }
}
